# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk webhook - add /api/webhooks/clerk in Dashboard, events: user.created, organizationMembership.created
CLERK_WEBHOOK_SIGNING_SECRET=
# Single org: create "NXT TIME PULSE" in Clerk Dashboard, copy org ID here (optional, for server-side org checks)
# CLERK_ORG_ID=

# Neon (GEO TIMESHEET - TIMEPULSE project)
DATABASE_URL=postgresql://user:pass@host-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:pass@host.region.aws.neon.tech/neondb?sslmode=require

# Mapbox (for geozone map display and polygon drawing)
# Address search uses OpenStreetMap Nominatim (free, no key)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Sentry (error monitoring - https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Kiosk mode — shared tablet time clock (optional, set to restrict kiosk API access)
KIOSK_SECRET=

# Vercel Cron — required for scheduled notification cron jobs
# Generate a strong random string (e.g. openssl rand -base64 32)
CRON_SECRET=

# Web Push (VAPID) — browser push notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional — defaults to mailto:notifications@timepulse.app
# VAPID_SUBJECT=mailto:notifications@timepulse.app

# Resend — transactional email notifications
# Get your API key at https://resend.com
RESEND_API_KEY=
# Optional — defaults to TimePulse <notifications@timepulse.nxtdotx.online>
# EMAIL_FROM=TimePulse <notifications@timepulse.nxtdotx.online>

# n8n (notification routing to email / WhatsApp / SMS)
# Create a webhook trigger in n8n and paste its URL here
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
